VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-supabase-anon-key

# Enable Google and GitHub in Supabase Dashboard > Authentication > Providers.
# Add these redirect URLs in Supabase Dashboard > Authentication > URL Configuration:
# http://localhost:3975/auth/callback
# http://localhost:3975/revision
# http://localhost:3975/update-password
# https://your-production-domain.com/auth/callback
# https://your-production-domain.com/revision
# https://your-production-domain.com/update-password
#
# Provider keys must not be exposed as VITE_* variables.
# Store demo AI keys as Supabase Edge Function secrets instead:
# supabase secrets set OPENROUTER_API_KEY=... GROQ_API_KEY=... OPENAI_API_KEY=...

# Resend API Key for Server-side secure feedback delivery
RESEND_API_KEY=your_resend_api_key_here

