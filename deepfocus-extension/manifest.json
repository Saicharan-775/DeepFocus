{
  "manifest_version": 3,
  "name": "DeepFocus – DSA Focus & Revision",
  "version": "1.0.2",
  "description": "A focus environment for LeetCode to prevent cheating and maintain discipline via timer and score.",
  "permissions": [
    "storage",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "*://leetcode.com/*",
    "*://*.leetcode.com/*",
    "*://*.supabase.co/*",
    "https://deepfocus.qzz.io/*",
    "https://api.groq.com/*",
    "https://openrouter.ai/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://www.leetcode.com/*",
        "https://*.leetcode.com/*",
        "https://deepfocus.qzz.io/*"
      ],
      "css": ["styles/widget.css"],
      "js": ["config.js", "utils/soundManager.js", "content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/blocked-overlay.html",
        "content/blocked-overlay.js",
        "utils/pageInterceptor.js",
        "assets/icons/*",
        "assets/deepfocus-logo.png",
        "sounds/success.mp3",
        "sounds/fail.mp3"
      ],
      "matches": [
        "*://leetcode.com/*",
        "*://*.leetcode.com/*",
       "https://deepfocus.qzz.io/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
